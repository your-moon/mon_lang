функц тестТоо64(н тоо64) -> тоо64 {
    буц н + 1;
}

функц үндсэн() -> тоо {
    // Test 1: тоо64 literal arithmetic
    зарла а: тоо64 = 100;
    зарла б: тоо64 = 200;
    хэвлэ(а + б);
    мөр_хэвлэх(" ");

    // Test 2: mixed тоо + тоо64 arithmetic
    зарла в: тоо = 10;
    зарла г: тоо64 = 20;
    хэвлэ(в + г);
    мөр_хэвлэх(" ");

    // Test 3: тоо assigned to тоо64 var
    зарла д: тоо64 = 42;
    хэвлэ(д);
    мөр_хэвлэх(" ");

    // Test 4: тоо passed to тоо64 param
    зарла е: тоо = 99;
    хэвлэ(тестТоо64(е));
    мөр_хэвлэх("\n");

    буц 0;
}
