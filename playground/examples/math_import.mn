// Математик сан ашиглах - Using Math Library
ашигла "math.mn";

функц үндсэн() -> тоо {
    мөр_хэвлэх("|-5| = ");
    хэвлэ(үнэмлэхүй(-5));
    мөр_хэвлэх("\n");

    мөр_хэвлэх("их(10, 20) = ");
    хэвлэ(их(10, 20));
    мөр_хэвлэх("\n");

    мөр_хэвлэх("бага(10, 20) = ");
    хэвлэ(бага(10, 20));
    мөр_хэвлэх("\n");

    мөр_хэвлэх("2^8 = ");
    хэвлэ(зэрэг(2, 8));
    мөр_хэвлэх("\n");

    мөр_хэвлэх("5! = ");
    хэвлэ(факториал(5));
    мөр_хэвлэх("\n");

    буц 0;
}
