функц үндсэн() -> тоо {
    // Test 1: while with break
    зарла i: тоо = 0;
    давтах i < 10 бол {
        хэрэв i == 3 бол {
            зогс;
        }
        i = i + 1;
    }
    хэвлэ(i);
    мөр_хэвлэх(" ");

    // Test 2: while with continue
    зарла j: тоо = 0;
    зарла сум: тоо = 0;
    давтах j < 5 бол {
        j = j + 1;
        хэрэв j == 3 бол {
            үргэлжлүүл;
        }
        сум = сум + j;
    }
    хэвлэ(сум);
    мөр_хэвлэх(" ");

    // Test 3: nested loops with inner break
    зарла а: тоо = 0;
    зарла гадна: тоо = 0;
    давтах гадна < 3 бол {
        зарла дотор: тоо = 0;
        давтах дотор < 10 бол {
            хэрэв дотор == 2 бол {
                зогс;
            }
            дотор = дотор + 1;
        }
        а = а + дотор;
        гадна = гадна + 1;
    }
    хэвлэ(а);
    мөр_хэвлэх(" ");

    // Test 4: if / else-if / else
    зарла x: тоо = 2;
    хэрэв x == 1 бол {
        хэвлэ(10);
    } эсвэл хэрэв x == 2 бол {
        хэвлэ(20);
    } эсвэл {
        хэвлэ(30);
    }
    мөр_хэвлэх(" ");

    // Test 5: ternary
    зарла t: тоо = 1 == 1 ? 99 : 0;
    хэвлэ(t);
    мөр_хэвлэх("\n");

    буц 0;
}
