// Binary operations
функц майн() -> тоо {
    зарла нэмэх: тоо = 5 + 5;       // 10
    зарла хасах: тоо = 1 - 1;       // 0
    зарла үржих: тоо = 2 * 2;       // 4
    зарла хуваах: тоо = 1 / 1;      // 1
    зарла ба: тоо = 1 == 1 && 2 == 2;   // 1
    зарла эсвэл: тоо = 1 == 1 || 2 == 2; // 1
    зарла үгүйсгэл: тоо = !1;      // 0

    буц нэмэх + хасах + үржих + хуваах; // 15
}
