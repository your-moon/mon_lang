функц үндсэн() -> тоо {
    // Simple precedence
    зарла а:тоо = 10 + 3 * 5;     // out: 25
    зарла б:тоо = (10 + 3) * 5;   // out: 65
    зарла в:тоо = 20 - 4 * 3 + 2; // out: 10

    // More complex
    зарла г:тоо = 5 + 3 * 2 + 8 / 4;     // 5 + 6 + 2 = 13
    зарла д:тоо = (5 + 3) * (2 + 8) / 4;  // 8 * 10 / 4 = 20
    зарла е:тоо = 2 * 3 * 4 + 6 / 2;      // 24 + 3 = 27

    хэрэв г > д && д < е || г == 13 бол {
        зарла ж:тоо = 1;
    }

    зарла з:тоо = (г + д) * (е - 5) / (2 + 1);  // (13 + 20) * (27 - 5) / 3 = 242

    // Logical precedence
    зарла и:тоо = 5;
    зарла к:тоо = 10;
    зарла л:тоо = 15;

    хэрэв и < к && к < л || и > л бол {
        зарла м:тоо = 1;
    }

    хэрэв (и < к || к > л) && и < л бол {
        зарла н:тоо = 2;
    }

    // Ternary
    зарла о:тоо = 12;
    зарла п:тоо = 5;
    зарла р:тоо = 2;

    зарла с:тоо = о > п ? 1 : 0;  // 1
    зарла т:тоо = о > п ?
                  п > р ? 2 : 3 :
                  р > п ? 4 : 5;  // 2
    зарла у:тоо = о + п > р * 5 ?
                  о * 2 :
                  п * 3;  // 24

    буц с + т + у;  // 27
}
