// Фибоначчи тоо - Fibonacci
функц фибоначчи(н: тоо) -> тоо {
    хэрэв н <= 1 бол {
        буц н;
    }
    буц фибоначчи(н - 1) + фибоначчи(н - 2);
}

функц үндсэн() -> тоо {
    зарла i: тоо = 0;
    давтах i < 15 бол {
        хэвлэ(фибоначчи(i));
        мөр_хэвлэх(" ");
        i = i + 1;
    }
    мөр_хэвлэх("\n");
    буц 0;
}
